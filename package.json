{
  "name": "pulsesync-example-addon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PulseSync addon template built with Vite",
  "scripts": {
    "dev": "node ./scripts/dev-build.mjs",
    "build": "vite build",
    "format": "prettier --write .",
    "sync": "node ./scripts/sync-addon.mjs",
    "build:sync": "yarn build && yarn sync"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.5",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
